{
	"editor.detectIndentation": false,
	"editor.formatOnSave": true,
	"editor.insertSpaces": false,
	"editor.tabSize": 2,
	"editor.unicodeHighlight.allowedCharacters": {
		// characters common in figma designs
		"’": true
	},
	"editor.pasteAs.enabled": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "always",
		"source.fixAll.ts": "never"
	},
	"files.eol": "\n",
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg/store/**": true
	},
	"files.associations": {
		"*.css": "tailwindcss",
	},
	"terminal.integrated.cwd": "${workspaceFolder}/packages/app",
	"typescript.tsdk": "node_modules/typescript/lib",
	"typescript.enablePromptUseWorkspaceTsdk": true,
	"typescript.preferences.importModuleSpecifier": "relative",
	"typescript.preferences.importModuleSpecifierEnding": "js",
	"javascript.preferences.importModuleSpecifier": "relative",
	"javascript.preferences.importModuleSpecifierEnding": "js",
	"eslint.workingDirectories": [
		"packages/app"
	],
	"markdown.copyFiles.destination": {
		"**/*": "docs-assets/${documentRelativeDirName}${fileName}"
	},
	"tailwindCSS.experimental.configFile": "packages/app/src/app.css",
	"workbench.colorCustomizations": {
		"activityBar.background": "#2d3748",
		"activityBar.foreground": "#ffffff",
	},
	"vsicons.presets.angular": true,
	"oxc.fmt.configPath": "packages/app/vite.config.ts",
	"oxc.enable.oxfmt": true,
	"oxc.enable.oxlint": false,
}