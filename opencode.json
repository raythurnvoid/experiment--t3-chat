{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "question": "deny",
    "websearch": "allow"
  },
  "mcp": {
    "playwriter": {
      "type": "local",
      "command": ["pnpx", "playwriter@latest"],
      "enabled": true,
      "environment": {
        "PLAYWRITER_AUTO_ENABLE": "1",
        "PWDEBUG": "console"
      }
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "chrome_devtools": {
      "type": "local",
      "command": [
        "pnpx",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222"
      ],
      "enabled": true,
      "environment": {}
    }
  }
}
