{
	"$schema": "https://unpkg.com/wrangler/config-schema.json",
	"name": "bonobo-senate-plugin-runner",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-01",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": true,
	"vars": {
		"PLUGIN_RUNNER_ARTIFACT_PREFIX": "plugins/"
	},
	"secrets": {
		"required": [
			"PLUGIN_RUNNER_SECRET",
			"OPENAI_API_KEY",
			"MODAL_FILE_CONVERTER_URL",
			"MODAL_TOKEN",
			"CLOUDFLARE_MEDIA_TRANSFORMER_URL",
			"CLOUDFLARE_MEDIA_TRANSFORMER_SECRET"
		]
	},
	"worker_loaders": [{ "binding": "LOADER" }],
	"r2_buckets": [
		{
			"binding": "PLUGIN_ARTIFACTS",
			"bucket_name": "bonobo-senate-press-files"
		}
	],
	"observability": {
		"enabled": true
	}
}
